#!/bin/bash

module load cpe/26.03
module load rocm/7.0.2
module load cray-hdf5-parallel
module load craype-accel-amd-gfx90a


export MPICH_GPU_SUPPORT_ENABLED=1
export LD_LIBRARY_PATH=${CRAY_LD_LIBRARY_PATH}:${LD_LIBRARY_PATH}

# Cray MPI NIC selection: "NUMA" assigns each rank to the NIC closest to its
# NUMA domain, which reduces cross-die traffic for MPI messages.  On Frontier
# each node has 4 NICs (one per GCD pair), so this keeps neighboring ranks'
# traffic on the nearest NIC when possible.
export MPICH_OFI_NIC_POLICY=NUMA

# Abort (rather than silently fall back to host staging) if a GPU pointer
# cannot be registered — surfaces configuration mistakes early.
export MPICH_GPU_NO_FALLBACK=${MPICH_GPU_NO_FALLBACK:-1}
